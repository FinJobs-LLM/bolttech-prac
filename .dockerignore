# Keep the build context small and the image clean.

# Python virtual environment (rebuilt inside the image from uv.lock)
.venv/
venv/

# Python caches
__pycache__/
*.py[cod]
.ipynb_checkpoints/

# MLflow tracking store + CatBoost logs (regenerated by training)
mlruns/
mlflow.db
catboost_info/

# Front-end (separate app; not part of the serving image)
frontend/

# Git / CI / editor
.git/
.gitignore
.vscode/
.idea/

# Notebooks and instructions (not needed at runtime)
notebooks/
instructions/

# OS files
.DS_Store
