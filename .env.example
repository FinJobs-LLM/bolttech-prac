# Copy to .env and fill in. .env is git-ignored and loaded automatically by
# src/config.py (via python-dotenv) for the FastAPI servers.

# Required only for the LLM explanation endpoints (GET /explain, /explain-prediction*).
OPENAI_API_KEY=

# AWS RDS MySQL — optional. If set, every /predict is saved to the
# `claim_predictions` table (one row per prediction). If unset, prediction
# serving works exactly as before (no persistence).
DB_HOST=
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASSWORD=
